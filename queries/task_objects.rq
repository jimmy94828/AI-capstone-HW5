PREFIX cap: <https://hcis.io/ontology/aicapstone/2026/>
PREFIX g13: <https://hcis.io/ontology/aicapstone/2026/group13/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>

SELECT DISTINCT ?obj ?label ?objectType ?role ?affordance
WHERE {
  ?obj rdf:type ?objectType .

  FILTER(STRSTARTS(STR(?obj), STR(g13:)))

  ?objectType rdfs:subClassOf* cap:PhysicalObject .

  FILTER(isIRI(?objectType))
  FILTER(?objectType != cap:PhysicalObject)
  FILTER(?objectType != cap:GraspableObject)
  FILTER(?objectType != owl:NamedIndividual)

  OPTIONAL { ?obj cap:hasObjectLabel ?label . }
  OPTIONAL { ?obj cap:hasTaskRole ?role . }
  OPTIONAL { ?obj cap:hasAffordance ?affordance . }
}
ORDER BY ?obj ?objectType ?role ?affordance