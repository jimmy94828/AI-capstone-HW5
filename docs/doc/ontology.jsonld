}, {
  "@id" : "https://hcis.io/ontology/aicapstone/2026/ContainerTarget",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A task role for an object that receives or contains other objects, such as the basket in toy block collection."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "container target"
  } ],
  "http://www.w3.org/2004/02/skos/core#relatedMatch" : [ {
    "@id" : "http://www.ease-crc.org/ont/SOMA.owl#Deposit"
  }, {
    "@id" : "http://www.ease-crc.org/ont/SOMA.owl#Deposition"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "This term is used locally to describe the role of a container in the course task, not to assert equivalence with a SOMA action or process class."
  } ]
}, {
  "@id" : "https://hcis.io/ontology/aicapstone/2026/EndEffector",
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A robot component used to physically interact with objects, such as a gripper."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "end effector"
  } ],
  "http://www.w3.org/2004/02/skos/core#relatedMatch" : [ {
    "@id" : "http://www.ease-crc.org/ont/SOMA.owl#Gripper"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "This homework treats end effectors at a simplified level sufficient for graspability reasoning."
  } ]
}, {
  "@id" : "https://hcis.io/ontology/aicapstone/2026/GraspableObject",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A physical object inferred to be graspable because it has at least one grasping affordance."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "graspable object"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A physical object inferred to afford grasping by a robot end effector in the task context."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "graspable object"
  } ],
  "http://www.w3.org/2004/02/skos/core#relatedMatch" : [ {
    "@id" : "http://www.ease-crc.org/ont/SOMA.owl#MovedObject"
  }, {
    "@id" : "http://www.ease-crc.org/ont/SOMA.owl#Patient"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "This is a course-level inferred class. It should not be treated as equivalent to a SOMA role such as soma:MovedObject or soma:Patient, because those terms describe participation roles in activities rather than the local OWL classification rule used in this homework."
  } ]
}, {
  "@id" : "https://hcis.io/ontology/aicapstone/2026/GraspingAffordance",
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An affordance by which an object can be grasped, held, lifted, or repositioned by a robot gripper."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "grasping affordance"
  } ],
  "http://www.w3.org/2004/02/skos/core#relatedMatch" : [ {
    "@id" : "http://www.ease-crc.org/ont/SOMA.owl#Disposition"
  }, {
    "@id" : "http://www.ease-crc.org/ont/SOMA.owl#Grasping"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "The course term is represented locally as an affordance class. SOMA models affordance-like knowledge through dispositions and task-oriented action descriptions; therefore relatedMatch is used rather than exactMatch."
  } ]
}, {
  "@id" : "https://hcis.io/ontology/aicapstone/2026/ManipulationTask",
  "http://www.w3.org/2004/02/skos/core#broadMatch" : [ {
    "@id" : "http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Task"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A robot task in which an agent changes the pose, state, or arrangement of physical objects."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "manipulation task"
  } ],
  "http://www.w3.org/2004/02/skos/core#relatedMatch" : [ {
    "@id" : "http://www.ease-crc.org/ont/SOMA.owl#Manipulating"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "The course term covers the project tasks, including cup stacking, cutlery arrangement, and toy block collection."
  } ]
}, {
  "@id" : "https://hcis.io/ontology/aicapstone/2026/PhysicalObject",
  "http://www.w3.org/2004/02/skos/core#closeMatch" : [ {
    "@id" : "http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#PhysicalObject"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A material object in the task environment, such as a cup, fork, toy block, plate, or basket."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "physical object"
  } ],
  "http://www.w3.org/2004/02/skos/core#relatedMatch" : [ {
    "@id" : "http://www.ease-crc.org/ont/SOMA.owl#ShapedObject"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "The course term is intentionally broad. DUL provides a foundational physical-object category, while SOMA provides robotics-oriented refinements for embodied activity contexts."
  } ]
}, {
  "@id" : "https://hcis.io/ontology/aicapstone/2026/ReferenceObject",
