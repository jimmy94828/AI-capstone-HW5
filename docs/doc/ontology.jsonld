    "@value" : "A robot or robot-controlled agent that can perceive, reason about, and manipulate objects in the task environment."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "robot agent"
  } ],
  "http://www.w3.org/2004/02/skos/core#relatedMatch" : [ {
    "@id" : "http://purl.org/ieee1872-owl/sumo-cora#Agent"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "The course term is aligned with CORA at the level of robot-as-agent or robot-as-system. It remains locally defined for the purposes of this homework."
  } ]
