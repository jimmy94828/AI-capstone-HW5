#################################################################
#    Classes
#################################################################

###  http://xmlns.com/foaf/0.1/Group
<http://xmlns.com/foaf/0.1/Group> rdf:type owl:Class .


###  https://hcis.io/ontology/aicapstone/2026/GraspableObject
<https://hcis.io/ontology/aicapstone/2026/GraspableObject> rdf:type owl:Class ;
                                                           owl:equivalentClass [ owl:intersectionOf ( <https://hcis.io/ontology/aicapstone/2026/PhysicalObject>
                                                                                                      [ rdf:type owl:Restriction ;
                                                                                                        owl:onProperty <https://hcis.io/ontology/aicapstone/2026/hasAffordance> ;
                                                                                                        owl:someValuesFrom <https://hcis.io/ontology/aicapstone/2026/GraspingAffordance>
                                                                                                      ]
                                                                                                    ) ;
                                                                                 rdf:type owl:Class
                                                                               ] ;
                                                           rdfs:comment "A physical object inferred to be graspable because it has at least one grasping affordance."@en ;
                                                           rdfs:label "graspable object"@en ;
                                                           <http://www.w3.org/2004/02/skos/core#definition> "A physical object inferred to afford grasping by a robot end effector in the task context."@en ;
                                                           <http://www.w3.org/2004/02/skos/core#prefLabel> "graspable object"@en ;
                                                           <http://www.w3.org/2004/02/skos/core#relatedMatch> <http://www.ease-crc.org/ont/SOMA.owl#MovedObject> ,
                                                                                                              <http://www.ease-crc.org/ont/SOMA.owl#Patient> ;
                                                           <http://www.w3.org/2004/02/skos/core#scopeNote> "This is a course-level inferred class. It should not be treated as equivalent to a SOMA role such as soma:MovedObject or soma:Patient, because those terms describe participation roles in activities rather than the local OWL classification rule used in this homework."@en .


###  https://hcis.io/ontology/aicapstone/2026/GraspingAffordance
<https://hcis.io/ontology/aicapstone/2026/GraspingAffordance> <http://www.w3.org/2004/02/skos/core#definition> "An affordance by which an object can be grasped, held, lifted, or repositioned by a robot gripper."@en ;
                                                              <http://www.w3.org/2004/02/skos/core#prefLabel> "grasping affordance"@en ;
                                                              <http://www.w3.org/2004/02/skos/core#relatedMatch> <http://www.ease-crc.org/ont/SOMA.owl#Disposition> ,
                                                                                                                 <http://www.ease-crc.org/ont/SOMA.owl#Grasping> ;
                                                              <http://www.w3.org/2004/02/skos/core#scopeNote> "The course term is represented locally as an affordance class. SOMA models affordance-like knowledge through dispositions and task-oriented action descriptions; therefore relatedMatch is used rather than exactMatch."@en .


###  https://hcis.io/ontology/aicapstone/2026/ManipulationTask
<https://hcis.io/ontology/aicapstone/2026/ManipulationTask> <http://www.w3.org/2004/02/skos/core#broadMatch> <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Task> ;
                                                            <http://www.w3.org/2004/02/skos/core#definition> "A robot task in which an agent changes the pose, state, or arrangement of physical objects."@en ;
                                                            <http://www.w3.org/2004/02/skos/core#prefLabel> "manipulation task"@en ;
                                                            <http://www.w3.org/2004/02/skos/core#relatedMatch> <http://www.ease-crc.org/ont/SOMA.owl#Manipulating> ;
                                                            <http://www.w3.org/2004/02/skos/core#scopeNote> "The course term covers the project tasks, including cup stacking, cutlery arrangement, and toy block collection."@en .


###  https://hcis.io/ontology/aicapstone/2026/PhysicalObject
<https://hcis.io/ontology/aicapstone/2026/PhysicalObject> <http://www.w3.org/2004/02/skos/core#closeMatch> <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#PhysicalObject> ;
                                                          <http://www.w3.org/2004/02/skos/core#definition> "A material object in the task environment, such as a cup, fork, toy block, plate, or basket."@en ;
                                                          <http://www.w3.org/2004/02/skos/core#prefLabel> "physical object"@en ;
                                                          <http://www.w3.org/2004/02/skos/core#relatedMatch> <http://www.ease-crc.org/ont/SOMA.owl#ShapedObject> ;
                                                          <http://www.w3.org/2004/02/skos/core#scopeNote> "The course term is intentionally broad. DUL provides a foundational physical-object category, while SOMA provides robotics-oriented refinements for embodied activity contexts."@en .


#################################################################
#    Individuals
#################################################################

###  https://hcis.io/ontology/aicapstone/2026/CollectableObject
<https://hcis.io/ontology/aicapstone/2026/CollectableObject> rdf:type owl:NamedIndividual .


###  https://hcis.io/ontology/aicapstone/2026/ContainerTarget
<https://hcis.io/ontology/aicapstone/2026/ContainerTarget> rdf:type owl:NamedIndividual ;
                                                           <http://www.w3.org/2004/02/skos/core#definition> "A task role for an object that receives or contains other objects, such as the basket in toy block collection."@en ;
                                                           <http://www.w3.org/2004/02/skos/core#prefLabel> "container target"@en ;
                                                           <http://www.w3.org/2004/02/skos/core#relatedMatch> <http://www.ease-crc.org/ont/SOMA.owl#Deposit> ,
                                                                                                              <http://www.ease-crc.org/ont/SOMA.owl#Deposition> ;
                                                           <http://www.w3.org/2004/02/skos/core#scopeNote> "This term is used locally to describe the role of a container in the course task, not to assert equivalence with a SOMA action or process class."@en .


###  https://hcis.io/ontology/aicapstone/2026/ReferenceObject
<https://hcis.io/ontology/aicapstone/2026/ReferenceObject> rdf:type owl:NamedIndividual .


###  https://hcis.io/ontology/aicapstone/2026/TargetObject
<https://hcis.io/ontology/aicapstone/2026/TargetObject> rdf:type owl:NamedIndividual .


###  https://hcis.io/ontology/aicapstone/2026/group13/basket01
:basket01 rdf:type owl:NamedIndividual ,
                   <https://hcis.io/ontology/aicapstone/2026/Basket> ;
          <https://hcis.io/ontology/aicapstone/2026/hasAffordance> :containmentAffordance ;
          <https://hcis.io/ontology/aicapstone/2026/hasTaskRole> <https://hcis.io/ontology/aicapstone/2026/ContainerTarget> ;
          <https://hcis.io/ontology/aicapstone/2026/hasObjectLabel> "basket" ;
          <https://hcis.io/ontology/aicapstone/2026/hasPoseFrame> "world/object_basket" ;
          rdfs:comment "The basket instance used as the container target for toy block collection."@en ;
          rdfs:label "basket 01"@en .


###  https://hcis.io/ontology/aicapstone/2026/group13/block01
:block01 rdf:type owl:NamedIndividual ,
                  <https://hcis.io/ontology/aicapstone/2026/ToyBlock> ;
         <https://hcis.io/ontology/aicapstone/2026/hasAffordance> :graspingAffordance ;
         <https://hcis.io/ontology/aicapstone/2026/hasTaskRole> <https://hcis.io/ontology/aicapstone/2026/CollectableObject> ;
         <https://hcis.io/ontology/aicapstone/2026/hasObjectLabel> "toy_block" ;
         <https://hcis.io/ontology/aicapstone/2026/hasPoseFrame> "world/object_block_01" ;
         rdfs:comment "A toy block instance that should be collected into the basket."@en ;
