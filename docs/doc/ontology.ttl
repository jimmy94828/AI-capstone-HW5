                                                     <http://purl.org/dc/terms/title> "Group 13 Semantic Affordance Grounding Ontology"@en ;
                                                     <http://purl.org/vocab/vann/preferredNamespacePrefix> "g13" ;
                                                     <http://purl.org/vocab/vann/preferredNamespaceUri> "https://hcis.io/ontology/aicapstone/2026/group13/" ;
                                                     rdfs:comment "A group-authored ontology for grounding course task objects, task roles, manipulation affordances, and inferred graspability."@en ;
                                                     rdfs:label "Group 13 Semantic Affordance Grounding Ontology"@en .

