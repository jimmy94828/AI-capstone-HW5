<https://hcis.io/ontology/aicapstone/2026/group13/> rdf:type owl:Ontology ;
                                                     owl:imports <file:/home/franciscobrizuela/Documents/classes2/AICapstone/HW/ai-capstone26/hw5/semantic-affordance-grounding/ontology/imports/course-affordance.ttl> ;
                                                     <http://purl.org/dc/terms/created> "2026-06-01"^^xsd:date ;
                                                     <http://purl.org/dc/terms/creator> :group13 ;
                                                     <http://purl.org/dc/terms/description> "This ontology defines group-specific object instances for the AI Capstone semantic grounding homework and uses OWL reasoning to infer graspable objects."@en ;
