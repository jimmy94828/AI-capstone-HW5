        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://hcis.io/ontology/aicapstone/2026/hasAffordance"/>
                <owl:someValuesFrom rdf:resource="https://hcis.io/ontology/aicapstone/2026/GraspingAffordance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://hcis.io/ontology/aicapstone/2026/hasAffordance"/>
                <owl:someValuesFrom rdf:resource="https://hcis.io/ontology/aicapstone/2026/group13/WipingAffordance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A cloth object in the dining-cleanup advanced task. It is graspable and can be used as a wiping tool.</rdfs:comment>
        <rdfs:label xml:lang="en">cloth</rdfs:label>
