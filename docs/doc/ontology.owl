    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://xmlns.com/foaf/0.1/Group -->


    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Group"/>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/GraspableObject -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/GraspableObject">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://hcis.io/ontology/aicapstone/2026/hasAffordance"/>
                        <owl:someValuesFrom rdf:resource="https://hcis.io/ontology/aicapstone/2026/GraspingAffordance"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">A physical object inferred to be graspable because it has at least one grasping affordance.</rdfs:comment>
        <rdfs:label xml:lang="en">graspable object</rdfs:label>
        <skos:definition xml:lang="en">A physical object inferred to afford grasping by a robot end effector in the task context.</skos:definition>
        <skos:prefLabel xml:lang="en">graspable object</skos:prefLabel>
        <skos:relatedMatch rdf:resource="http://www.ease-crc.org/ont/SOMA.owl#MovedObject"/>
        <skos:relatedMatch rdf:resource="http://www.ease-crc.org/ont/SOMA.owl#Patient"/>
        <skos:scopeNote xml:lang="en">This is a course-level inferred class. It should not be treated as equivalent to a SOMA role such as soma:MovedObject or soma:Patient, because those terms describe participation roles in activities rather than the local OWL classification rule used in this homework.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/GraspingAffordance -->


    <rdf:Description rdf:about="https://hcis.io/ontology/aicapstone/2026/GraspingAffordance">
        <skos:definition xml:lang="en">An affordance by which an object can be grasped, held, lifted, or repositioned by a robot gripper.</skos:definition>
        <skos:prefLabel xml:lang="en">grasping affordance</skos:prefLabel>
        <skos:relatedMatch rdf:resource="http://www.ease-crc.org/ont/SOMA.owl#Disposition"/>
        <skos:relatedMatch rdf:resource="http://www.ease-crc.org/ont/SOMA.owl#Grasping"/>
        <skos:scopeNote xml:lang="en">The course term is represented locally as an affordance class. SOMA models affordance-like knowledge through dispositions and task-oriented action descriptions; therefore relatedMatch is used rather than exactMatch.</skos:scopeNote>
    </rdf:Description>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/ManipulationTask -->


    <rdf:Description rdf:about="https://hcis.io/ontology/aicapstone/2026/ManipulationTask">
        <skos:broadMatch rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Task"/>
        <skos:definition xml:lang="en">A robot task in which an agent changes the pose, state, or arrangement of physical objects.</skos:definition>
        <skos:prefLabel xml:lang="en">manipulation task</skos:prefLabel>
        <skos:relatedMatch rdf:resource="http://www.ease-crc.org/ont/SOMA.owl#Manipulating"/>
        <skos:scopeNote xml:lang="en">The course term covers the project tasks, including cup stacking, cutlery arrangement, and toy block collection.</skos:scopeNote>
    </rdf:Description>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/PhysicalObject -->


    <rdf:Description rdf:about="https://hcis.io/ontology/aicapstone/2026/PhysicalObject">
        <skos:closeMatch rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#PhysicalObject"/>
        <skos:definition xml:lang="en">A material object in the task environment, such as a cup, fork, toy block, plate, or basket.</skos:definition>
        <skos:prefLabel xml:lang="en">physical object</skos:prefLabel>
        <skos:relatedMatch rdf:resource="http://www.ease-crc.org/ont/SOMA.owl#ShapedObject"/>
        <skos:scopeNote xml:lang="en">The course term is intentionally broad. DUL provides a foundational physical-object category, while SOMA provides robotics-oriented refinements for embodied activity contexts.</skos:scopeNote>
    </rdf:Description>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://hcis.io/ontology/aicapstone/2026/CollectableObject -->


    <owl:NamedIndividual rdf:about="https://hcis.io/ontology/aicapstone/2026/CollectableObject"/>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/ContainerTarget -->


    <owl:NamedIndividual rdf:about="https://hcis.io/ontology/aicapstone/2026/ContainerTarget">
        <skos:definition xml:lang="en">A task role for an object that receives or contains other objects, such as the basket in toy block collection.</skos:definition>
        <skos:prefLabel xml:lang="en">container target</skos:prefLabel>
        <skos:relatedMatch rdf:resource="http://www.ease-crc.org/ont/SOMA.owl#Deposit"/>
        <skos:relatedMatch rdf:resource="http://www.ease-crc.org/ont/SOMA.owl#Deposition"/>
        <skos:scopeNote xml:lang="en">This term is used locally to describe the role of a container in the course task, not to assert equivalence with a SOMA action or process class.</skos:scopeNote>
    </owl:NamedIndividual>
    


    <!-- https://hcis.io/ontology/aicapstone/2026/ReferenceObject -->


    <owl:NamedIndividual rdf:about="https://hcis.io/ontology/aicapstone/2026/ReferenceObject"/>
    


