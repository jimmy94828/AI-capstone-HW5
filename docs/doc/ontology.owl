    <rdf:Description rdf:about="https://hcis.io/ontology/aicapstone/2026/EndEffector">
        <skos:definition xml:lang="en">A robot component used to physically interact with objects, such as a gripper.</skos:definition>
        <skos:prefLabel xml:lang="en">end effector</skos:prefLabel>
        <skos:relatedMatch rdf:resource="http://www.ease-crc.org/ont/SOMA.owl#Gripper"/>
        <skos:scopeNote xml:lang="en">This homework treats end effectors at a simplified level sufficient for graspability reasoning.</skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://hcis.io/ontology/aicapstone/2026/RobotAgent">
        <skos:closeMatch rdf:resource="http://purl.org/ieee1872-owl/cora-bare#Robot"/>
        <skos:definition xml:lang="en">A robot or robot-controlled agent that can perceive, reason about, and manipulate objects in the task environment.</skos:definition>
        <skos:prefLabel xml:lang="en">robot agent</skos:prefLabel>
        <skos:relatedMatch rdf:resource="http://purl.org/ieee1872-owl/sumo-cora#Agent"/>
        <skos:scopeNote xml:lang="en">The course term is aligned with CORA at the level of robot-as-agent or robot-as-system. It remains locally defined for the purposes of this homework.</skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://hcis.io/ontology/aicapstone/2026/group13/CleanupTool">
        <rdfs:comment xml:lang="en">A task role for an object used as a tool during dining cleanup, such as the cloth used for wiping.</rdfs:comment>
        <rdfs:label xml:lang="en">cleanup tool</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://hcis.io/ontology/aicapstone/2026/group13/ProtectedObject">
        <rdfs:comment xml:lang="en">A task role for objects that should remain stable and undisturbed during the dining-cleanup task.</rdfs:comment>
        <rdfs:label xml:lang="en">protected object</rdfs:label>
    </rdf:Description>
</rdf:RDF>



