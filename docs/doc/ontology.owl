     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:aicapstone="https://hcis.io/ontology/aicapstone/2026/">
    <owl:Ontology rdf:about="https://hcis.io/ontology/aicapstone/2026/group13/">
        <owl:imports rdf:resource="file:/home/weichen/AI_capstone/AI-capstone-HW5/ontology/imports/course-affordance.ttl"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-06-01</terms:created>
        <terms:creator rdf:resource="https://hcis.io/ontology/aicapstone/2026/group13/group13"/>
        <terms:description xml:lang="en">This ontology defines group-specific object instances for the AI Capstone semantic grounding homework and uses OWL reasoning to infer graspable objects.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:title xml:lang="en">Group 13 Semantic Affordance Grounding Ontology</terms:title>
        <vann:preferredNamespacePrefix>g13</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://hcis.io/ontology/aicapstone/2026/group13/</vann:preferredNamespaceUri>
        <rdfs:comment xml:lang="en">A group-authored ontology for grounding course task objects, task roles, manipulation affordances, and inferred graspability.</rdfs:comment>
        <rdfs:label xml:lang="en">Group 13 Semantic Affordance Grounding Ontology</rdfs:label>
    </owl:Ontology>



