    </owl:Class>



    <!-- https://hcis.io/ontology/aicapstone/2026/group13/StabilityAffordance -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/group13/StabilityAffordance">
        <rdfs:subClassOf rdf:resource="https://hcis.io/ontology/aicapstone/2026/Affordance"/>
        <rdfs:comment xml:lang="en">An affordance indicating that an object should remain stable and undisturbed in the dining-cleanup task.</rdfs:comment>
        <rdfs:label xml:lang="en">stability affordance</rdfs:label>
    </owl:Class>



    <!-- https://hcis.io/ontology/aicapstone/2026/group13/Tissue -->


