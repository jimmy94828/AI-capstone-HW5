                <owl:someValuesFrom rdf:resource="https://hcis.io/ontology/aicapstone/2026/group13/StabilityAffordance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A tissue object in the dining-cleanup advanced task. It is protected and should remain stable rather than be grasped.</rdfs:comment>
        <rdfs:label xml:lang="en">tissue</rdfs:label>
    </owl:Class>



