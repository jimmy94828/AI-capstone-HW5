    <!-- https://hcis.io/ontology/aicapstone/2026/ContainerTarget -->


    <owl:NamedIndividual rdf:about="https://hcis.io/ontology/aicapstone/2026/ContainerTarget">
        <skos:definition xml:lang="en">A task role for an object that receives or contains other objects, such as the basket in toy block collection.</skos:definition>
        <skos:prefLabel xml:lang="en">container target</skos:prefLabel>
        <skos:relatedMatch rdf:resource="http://www.ease-crc.org/ont/SOMA.owl#Deposit"/>
        <skos:relatedMatch rdf:resource="http://www.ease-crc.org/ont/SOMA.owl#Deposition"/>
        <skos:scopeNote xml:lang="en">This term is used locally to describe the role of a container in the course task, not to assert equivalence with a SOMA action or process class.</skos:scopeNote>
    </owl:NamedIndividual>



