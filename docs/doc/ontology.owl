    <!-- https://hcis.io/ontology/aicapstone/2026/group13/cupStackingTask -->


    <owl:NamedIndividual rdf:about="https://hcis.io/ontology/aicapstone/2026/group13/cupStackingTask">
        <rdf:type rdf:resource="https://hcis.io/ontology/aicapstone/2026/ManipulationTask"/>
